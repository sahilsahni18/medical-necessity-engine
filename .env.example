# Copy to .env and fill in. .env is git-ignored.

# Required: get a free key from Google AI Studio (no credit card).
GEMINI_API_KEY=your-gemini-api-key-here

# Models (defaults are fine for the free tier).
GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIM=768

# "gemini" (default) or "local" (sentence-transformers fallback; set EMBEDDING_DIM=384).
EMBEDDING_PROVIDER=gemini

# Database (docker-compose sets this automatically inside the api container).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mna

# Protects the /admin/ingest endpoint.
ADMIN_TOKEN=change-me
